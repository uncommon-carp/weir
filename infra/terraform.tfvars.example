region      = "us-east-1"
name_prefix = "sentinel-gate"

# org/repos allowed to assume the CI role via OIDC — one entry per repo that
# calls scan.yml as a reusable workflow (include this repo itself, plus every
# target repo you've wired up per the "Connecting a target repo" README section)
github_repos = ["uncommon-carp/sentinel-gate"]

# Cost guardrails
billing_alarm_threshold_usd = 25
alarm_email                 = "" # set to receive billing alerts

# Set false if this AWS account already has a GitHub OIDC provider
create_oidc_provider = true
